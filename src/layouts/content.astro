---
import { Footer } from "@/components/layouts/Footer/Footer";
import { Header } from "@/components/layouts/Header/Header";

interface Props {
  title: string;
  label: string;
}

const { title, label } = Astro.props as Props;
---

<Header client:load />
    <section class="flex flex-col items-start p-4 ">
      <div class="flex flex-col gap-8 items-start py-40 px-12 w-full">
        <span class="text-sm border border-primary/50 rounded-full px-2 py-1 tracking-widest">{label}</span>
        <div class="w-full flex gap-40 items-stretch">
          <div class="text-left w-full flex flex-col">
            <h1 class="main-title font-bold text-primary/70 mb-2">{title}</h1>
          </div>
          <div class="flex flex-col md:flex-row gap-8 w-full justify-center items-stretch">
           <slot />
        </div>
      </div>
    </section>
<Footer />