---
import Head from "@/components/layouts/Head.astro";
import SmoothScroll from "@/components/layouts/SmoothScroll";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "D'acosta Labs — Laboratorio dental",
  description = "Laboratorio de prótesis dental digital. Precisión CAD/CAM y acabado artesanal.",
}: Props = Astro.props;
---

<!doctype html>
<html lang="es">
	<Head title={title} description={description} />
	<body>
		<SmoothScroll client:load>
			<slot />
		</SmoothScroll>
	</body>
</html>
