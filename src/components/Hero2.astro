---
import { Button } from "./ui/button";
import { Image } from "astro:assets";
import hero from "src/assets/hero-placeholder.png";
---

<div class="h-screen flex-col items-center justify-center text-center">
    <div class="img-wrapper relative w-full h-full overflow-hidden">
        <Image class=" object-cover" src={hero} alt="D'acosta labs" loading="lazy" />
    </div>
    <div class="absolute flex flex-col left-0 top-20 py-20 pl-24">
        <div class=" flex flex-col items-start  z-100 max-w-[50%] gap-4">
            <h1 class="main-title text-neutral text-left text-8xl">Diseñando tu sonrisa</h1>
        </div>
        <div class="flex flex-col items-start self-end z-100 max-w-[50%] gap-4">
            <Button className="font-semibold" variant="accent" size="xl">CONTACT US</Button>
        </div>
    </div>
   
</div>

<style>
	.img-wrapper::before {
		content: '';
		position: absolute;
		inset: 0;
		background:rgba(0, 0, 0, 0.3);
		z-index: 10;
	}
    .main-title{
        font-size: clamp(48px, 26.55px + 100vw * .055, 130px);;
    }
</style>
