---
import Hero from '@/components/Hero.astro';
import Services from '@/components/Services';
import Triad from '@/components/Triad/Triad.jsx';
import Layout from '@/layouts/layout.astro';
import Main from '@/layouts/main.astro';
---

<Layout>
	<Main>
		<Hero />
		<Triad client:load />
		<div class="sticky w-screen h-[200vh] flex items-center justify-center bg-primary">
			<h2 class="text-4xl font-bold text-white">Scroll down to see the magic!</h2>
		</div>
		<Services client:load />
	</Main>
</Layout>