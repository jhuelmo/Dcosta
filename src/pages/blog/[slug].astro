---
import Layout from "@/layouts/layout.astro";
import Main from "@/layouts/main.astro";
import BlockRenderer from "@/components/Services/ServicePage/BlockRenderer";
import { getPosts } from "@/lib/strapi/strapi";
import type { Post } from "@/lib/strapi/types";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL ?? import.meta.env.STRAPI_URL;
const date = new Date(post.publishedAt).toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={post.title}>
  <Main>
    <article class="container-text max-w-260 flex flex-col gap-12 px-4 lg:px-8 pt-56 pb-12">
      <header class="flex flex-col gap-4">
        <div class="flex items-center gap-2 text-sm text-textColor/60">
          <span class="font-medium">{post.category}</span>
          <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0" />
          <span>{date}</span>
        </div>
        <h1 class="text-3xl md:text-5xl font-semibold text-textColor leading-snug">
          {post.title}
        </h1>
      </header>

      {post.heroImage?.url && (
        <div class="w-full aspect-16/9 rounded-2xl overflow-hidden">
          <img
            src={`${STRAPI_URL}${post.heroImage.url}`}
            alt={post.heroImage.alternativeText ?? post.title}
            class="w-full h-full object-cover"
          />
        </div>
      )}
    </article>

    <BlockRenderer client:load blocks={post.body} className="container-text max-w-260" />
  </Main>
</Layout>
