---
import Layout from "@/layouts/layout.astro";
import Content from "@/layouts/content.astro";
import service1 from "@/assets/Services/Service-1.jpg";
import service2 from "@/assets/Services/Service-2.jpg";
import service3 from "@/assets/Services/Service-3.jpg";
import { Divider } from "@/components/ui/divider";

const projects = [
  {
    slug: "corona-1",
    title: "Corona 1",
    info: {
      role: "Prostodoncia",
      client: "Clínica Dental",
      technology: ["Zirconio", "CAD/CAM"],
    },
    image: service1.src,
  },
  {
    slug: "implante-1",
    title: "Implante 1",
    info: {
      role: "Implantología",
      client: "Centro Odontológico",
      technology: ["Zirconio", "Implantología"],
    },
    image: service2.src,
  },
  {
    slug: "corona-2",
    title: "Corona 2",
    info: {
      role: "Prostodoncia",
      client: "Consultorio Privado",
      technology: ["Zirconio"],
    },
    image: service3.src,
  },
  {
    slug: "implante-2",
    title: "Implante 2",
    info: {
      role: "Implantología",
      client: "Clínica Premium",
      technology: ["Titanio", "CAD/CAM"],
    },
    image: service1.src,
  },
];
---

<Layout>
  <Content title="Nuestro trabajo" label="GALERIA" type="center">
    <div class="mt-8 pt-8 grid grid-cols-1 gap-4">
      {
        projects.map((project) => (
          <article class="flex flex-row relative">
            <a
              href={`/works/${project.slug}`}
              class="block w-2/3 mx-auto rounded-3xl"
            >
              <img
                src={project.image}
                alt={project.title}
                loading="lazy"
                class=" object-cover aspect-4/3 md:aspect-16/10"
              />
            </a>
            <div class="sticky top-[50%] w-full">
              <span class="text-lg md:text-lg lg:text-lg leading-none">
                {project.info.role}
              </span>
              <span class="text-right text-lg md:text-lg lg:text-lg">
                {project.info.role}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </Content>
</Layout>
