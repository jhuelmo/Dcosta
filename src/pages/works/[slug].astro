---
import Layout from "@/layouts/layout.astro";
import Work from "@/layouts/work.astro";
import { WorkInfo } from "@/components/layouts/Works/workInfo";
import { Divider } from "@/components/ui/divider";
import { Gallery } from "@/components/layouts/Gallery";
import { getWorks } from "@/lib/strapi/strapi";
import type { Work as WorkData } from "@/lib/strapi/types";

export async function getStaticPaths() {
  const works = await getWorks();
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props as { work: WorkData };
const STRAPI_URL =
  import.meta.env.PUBLIC_STRAPI_URL ??
  import.meta.env.STRAPI_URL ??
  "http://localhost:1337";

const galleryRows = (work.gallery ?? []).map((image) => [
  `${STRAPI_URL}${image.url}`,
]);
---

<Layout>
  <Work title={work.title}>
    <div class="flex w-full space-y-6">
      <WorkInfo work={work} />
      <div class="flex-3 flex flex-col gap-6">
        <div class="rounded-3xl overflow-hidden">
          <img
            src={`${STRAPI_URL}${work.heroImage?.url}`}
            alt={work.title}
            class="object-cover aspect-16/10"
          />
        </div>

        <div class="flex flex-col box overflow-hidden mt-12">
          <Divider />
          <div class="flex">
            <div class="flex-1 uppercase text-sm font-bold text-primary/50">
              Descripción
            </div>
            <h2 class="flex-1 text-xl">
              {work.description}
            </h2>
          </div>

          {
            galleryRows.length > 0 && (
              <div class="flex flex-col box overflow-hidden mt-12">
                <Divider />
                <div class="flex flex-col">
                  <div class="flex-1 text-sm font-bold uppercase text-primary/50">
                    Galería
                  </div>
                  <Gallery className="mt-12" rows={galleryRows} />
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </Work>
</Layout>
