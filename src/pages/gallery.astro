---
import Layout from "@/layouts/layout.astro";
import Content from "@/layouts/content.astro";
import CursorBubble from "@/components/ui/cursorBubble";
import { Projects } from "@/components/Gallery/Projects";
import { getWorks } from "@/lib/strapi/strapi";

const works = await getWorks();
---

<Layout
  title="Galería — D'acosta Labs"
  description="Casos reales de nuestro laboratorio dental: coronas, implantes y prótesis fabricadas con flujo digital y acabado artesanal."
>
  <Content
    title="Nuestro trabajo"
    label="GALERIA"
    type="center"
    textExtra={`${works.length} Proyectos`}
  >
    <div class="mt-8 pt-8" data-hover>
      <Projects client:load works={works} />
    </div>
    <CursorBubble selector="[data-hover]" client:load />
  </Content>
</Layout>
