# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# ── Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))") ──
APP_KEYS="key1,key2,key3,key4"   # 4 valores base64 separados por comas
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# ── Database ─────────────────────────────────────────────
# Development (SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Production (PostgreSQL) — descomenta y rellena estas en el VPS
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/dacosta_cms
# DATABASE_SSL=false