{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "category": {
      "type": "string"
    },
    "icon": {
      "type": "enumeration",
      "enum": [
        "wrench",
        "settings",
        "zap",
        "heart",
        "star",
        "shield"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "extraText": {
      "type": "string"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "sections.rich-text",
        "sections.image",
        "sections.gallery"
      ]
    }
  }
}
