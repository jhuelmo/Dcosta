{
    "compilerOptions": {
        "jsx": "react",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "allowJs": true,
        "checkJs": false,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@components/*": ["./src/components/*"],
            "@pages/*": ["./src/pages/*"],
            "@layouts/*": ["./src/layouts/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "dacosta-strapi"]
}
